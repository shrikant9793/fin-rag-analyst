# =============================================================================
# config/guardrails/rails.co
# Colang 1.0 — Financial Compliance Rail Definitions
#
# These flows define the guardrail logic NeMo evaluates for every
# input query and every LLM output before it reaches the analyst.
# =============================================================================

# ---------------------------------------------------------------------------
# INPUT RAILS — validate the incoming analyst query
# ---------------------------------------------------------------------------

define user ask investment advice
  "should I buy"
  "should I sell"
  "should I invest"
  "is it a good time to buy"
  "will the stock go up"
  "should I hold"
  "what stocks should I buy"
  "give me investment advice"
  "recommend me a stock"

define flow check financial query appropriateness
  user ask investment advice
  bot refuse investment advice query

define bot refuse investment advice query
  "I'm a financial research assistant, not an investment advisor. I can help you analyse publicly available financial data, earnings reports, and SEC filings — but I cannot recommend whether to buy, sell, or hold any security. Please rephrase your question as a research or data analysis request."


# ---------------------------------------------------------------------------
# OUTPUT RAILS — validate every LLM-generated report section
# ---------------------------------------------------------------------------

# --- Rail 1: Block direct investment recommendations in output ---

define bot say investment recommendation
  "I recommend buying"
  "you should buy"
  "I recommend selling"
  "you should sell"
  "this is a buy"
  "strong buy"
  "outperform"
  "price target of"
  "target price"
  "I suggest investing"

define flow check investment advice
  bot say investment recommendation
  bot replace with disclaimer

define bot replace with disclaimer
  "⚠ [Compliance Flag] This section contained language that could be construed as an investment recommendation, which has been removed. Financial analysis is provided for informational purposes only and does not constitute investment advice."


# --- Rail 2: Block price predictions ---

define bot say price prediction
  "the stock will reach"
  "price will go to"
  "expected to hit"
  "will trade at"
  "forecasted price"
  "stock price will be"

define flow check price prediction
  bot say price prediction
  bot add prediction disclaimer

define bot add prediction disclaimer
  "⚠ [Compliance Flag] Forward-looking price statements have been removed. This system does not make price predictions. All analysis is based on historical data from source documents."


# --- Rail 3: Enforce source attribution ---

define flow check source attribution
  $has_claims = execute check_has_unsourced_claims(text=$last_bot_message)
  if $has_claims
    bot add attribution reminder

define bot add attribution reminder
  "\n\n> ℹ **Attribution Note:** Some statements in this section may lack explicit source citations. Please verify all material figures against the referenced source documents listed in the Data Sources section."


# --- Rail 4: Conditionally add disclaimer footer ---

define flow add compliance disclaimer if needed
  $needs_disclaimer = execute check_needs_disclaimer(text=$last_bot_message)
  if $needs_disclaimer
    bot append compliance footer

define bot append compliance footer
  "\n\n---\n> **Regulatory Disclaimer:** This report is generated by an AI system for internal research use only. It does not constitute investment advice, a solicitation, or a recommendation to buy or sell any security. Past performance is not indicative of future results."
